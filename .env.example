# ─────────────────────────────────────────────────────────────
# Supabase
# Supabase dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ─────────────────────────────────────────────────────────────
# App URL (éles: https://shiftsync.hu)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Resend (email küldés) — resend.com
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_<your-api-key>
RESEND_FROM_EMAIL=ShiftSync <noreply@shiftsync.hu>

# ─────────────────────────────────────────────────────────────
# Web Push (VAPID) — generálás: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<base64url-public-key>
VAPID_PRIVATE_KEY=<base64url-private-key>
VAPID_SUBJECT=mailto:<your-email>

# ─────────────────────────────────────────────────────────────
# OpenAI (AI beosztás, chat asszisztens)
# platform.openai.com → API keys
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-<your-api-key>

# ─────────────────────────────────────────────────────────────
# Stripe (előfizetés kezelés) — dashboard.stripe.com
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<your-secret-key>
STRIPE_PRICE_STARTER=price_<starter-price-id>
STRIPE_PRICE_PRO=price_<pro-price-id>
STRIPE_PRICE_ENTERPRISE=price_<enterprise-price-id>

# ─────────────────────────────────────────────────────────────
# TITKOSÍTÁSI KULCSOK — GDPR / Pseudonymizáció
# SOHA ne commitold a valódi kulcsokat!
# Generálás: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Mind a 3 kulcsot külön generáld!
# ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=<32-bájt-hex-kulcs-ide>
EMAIL_HASH_SECRET=<32-bájt-hex-kulcs-ide>
PSEUDONYM_SECRET=<32-bájt-hex-kulcs-ide>
